# SmartFarm web env example. Copy to `.env.local` and adjust.
#
# By default the app runs entirely against in-memory mock data so no backend
# is required. Set VITE_USE_MOCKS=false to wire the real SmartFarm API.

# Toggle live API. When "false" the store fetches from VITE_API_BASE_URL.
VITE_USE_MOCKS=true

# Base URL for the SmartFarm API. Used only when VITE_USE_MOCKS=false.
VITE_API_BASE_URL=http://localhost:4000

# Auth mode:
# - auto        mock for VITE_USE_MOCKS=true, otherwise dev_headers when
#               VITE_DEV_USER_ID and VITE_DEV_ORG_ID are present, else api
# - mock        seeded demo session
# - dev_headers bypass login and send tenant headers
# - api         use /api/v1/auth/login + refresh flow
VITE_AUTH_MODE=auto

# Local storage key for persisted API tokens.
VITE_AUTH_STORAGE_KEY=smartfarm.auth.session

# Tenant headers for dev_headers mode. These IDs must reference an existing
# user with a membership in the target organization.
VITE_DEV_USER_ID=
VITE_DEV_ORG_ID=

# Optional. Must match the user's persisted membership role if provided
# (admin | compliance_lead | expert | worker).
VITE_DEV_MEMBERSHIP_ROLE=
